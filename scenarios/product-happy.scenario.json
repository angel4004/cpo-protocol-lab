{
  "id": "product-happy",
  "mode": "product",
  "description": "Happy-path onboarding for an existing product. Source bundle is read from the cpo Git branch snapshot.",
  "source": {
    "type": "git_ref",
    "repoPath": "../cpo",
    "ref": "upstream",
    "fetchBeforeRead": true,
    "requireClean": true,
    "sourceDirs": [
      "runtime/core",
      "runtime/project_setup"
    ],
    "initialPromptPath": "runtime/project_setup/prompt_launch_cpo_copilot.md"
  },
  "fixturePath": "../fixtures/passports/product-happy.fixture.json",
  "contractPath": "../contracts/onboarding-product.mvp.contract.json",
  "draftAlreadyInSources": false,
  "maxTurns": 10,
  "temperature": 0.2,
  "seed": 12345,
  "reasoning": {
    "effort": "minimal",
    "exclude": true
  },
  "maxOutputTokens": {
    "copilot": 5000,
    "simulator": 1200
  },
  "models": {
    "copilot": "openai/gpt-5-mini",
    "simulator": "openai/gpt-5-mini",
    "evaluator": "deterministic"
  }
}
