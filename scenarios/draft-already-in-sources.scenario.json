{
  "id": "draft-already-in-sources",
  "mode": "product",
  "description": "Product onboarding where a draft passport already appeared in Sources before final snapshot.",
  "source": {
    "type": "git_ref",
    "repoPath": "../cpo",
    "ref": "upstream",
    "fetchBeforeRead": true,
    "requireClean": true,
    "sourceDirs": [
      "runtime/core",
      "runtime/project_setup"
    ],
    "initialPromptPath": "runtime/project_setup/prompt_launch_cpo_copilot.md"
  },
  "initialUserMessage": "У меня уже есть продукт. Похоже, черновик Project Passport случайно попал в Sources до финального снапшота.",
  "fixturePath": "../fixtures/passports/product-happy.fixture.json",
  "contractPath": "../contracts/draft-already-in-sources.mvp.contract.json",
  "draftAlreadyInSources": true,
  "maxTurns": 8,
  "temperature": 0.2,
  "seed": 12345,
  "reasoning": {
    "effort": "minimal",
    "exclude": true
  },
  "maxOutputTokens": {
    "copilot": 5000,
    "simulator": 1200
  },
  "models": {
    "copilot": "openai/gpt-5-mini",
    "simulator": "openai/gpt-5-mini",
    "evaluator": "deterministic"
  }
}
