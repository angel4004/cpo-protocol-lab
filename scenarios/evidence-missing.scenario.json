{
  "id": "evidence-missing",
  "mode": "product",
  "description": "Product onboarding where the passport lacks PMF/PCF/customer-success/business-impact evidence.",
  "source": {
    "type": "git_ref",
    "repoPath": "../cpo",
    "ref": "upstream",
    "fetchBeforeRead": true,
    "requireClean": true,
    "sourceDirs": [
      "runtime/core",
      "runtime/project_setup"
    ],
    "initialPromptPath": "runtime/project_setup/prompt_launch_cpo_copilot.md"
  },
  "initialUserMessage": "У меня уже есть продукт, но evidence по PMF, PCF и бизнес-эффекту пока нет.",
  "fixturePath": "../fixtures/passports/evidence-missing.fixture.json",
  "contractPath": "../contracts/evidence-missing.mvp.contract.json",
  "draftAlreadyInSources": false,
  "maxTurns": 8,
  "temperature": 0.2,
  "seed": 12345,
  "reasoning": {
    "effort": "minimal",
    "exclude": true
  },
  "maxOutputTokens": {
    "copilot": 5000,
    "simulator": 1200
  },
  "models": {
    "copilot": "openai/gpt-5-mini",
    "simulator": "openai/gpt-5-mini",
    "evaluator": "deterministic"
  }
}
